--   STATE
-- =============================================
local spamKickEnabled   = false
local spamNoKickEnabled = false
local antiTPEnabled     = false
local punishedPlayers   = {}
local antiTPCooldowns   = {}

local priorityCommands  = {"rocket", "balloon"}
local secondaryCommands = {"inverse", "tiny", "morph", "jumpscare"}
local defenseCommand    = "balloon"

-- =============================================
--   PLOT HELPERS
-- =============================================
function findMyPlot()
    local plots = workspace:FindFirstChild("Plots"); if not plots then return nil end
    for _, p in pairs(plots:GetChildren()) do
        local sign = p:FindFirstChild("PlotSign")
        if sign then
            local yourBase = sign:FindFirstChild("YourBase")
            if yourBase and yourBase:IsA("BillboardGui") and yourBase.Enabled then return p end
        end
    end
    local name = LocalPlayer.Name
    for _, p in pairs(plots:GetChildren()) do
        if string.find(p.Name, name) then return p end
        local owner = p:FindFirstChild("Owner")
        if owner and owner.Value == LocalPlayer then return p end
    end
    return nil
end

local function getPlayersInMyPlot()
    local myPlot = findMyPlot(); if not myPlot then return {} end
    local pos = myPlot:GetPivot().Position
    local decor = myPlot:FindFirstChild("Decorations")
    if decor then local model = decor:FindFirstChild("Model"); if model then pos = model:GetPivot().Position end end
    local inPlot = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - pos).Magnitude < 120 then table.insert(inPlot, plr) end
        end
    end
    return inPlot
end

local function stripTags(s) return string.gsub(s, "<.->", "") end

-- =============================================
--   DEFENSE ACTIONS
-- =============================================
local function executeAPSpam(targetName, shouldKick)
    local targetPlayer
    for _, p in ipairs(Players:GetPlayers()) do if p.Name == targetName then targetPlayer = p; break end end
    if not targetPlayer then return end
    sendCommand("balloon", targetPlayer)
    task.wait(0.02)
    sendCommand("jail", targetPlayer)
    task.wait(0.03)
    for _, cmd in ipairs(priorityCommands) do sendCommand(cmd, targetPlayer) end
    task.wait(0.03)
    for _, cmd in ipairs(secondaryCommands) do sendCommand(cmd, targetPlayer) end
    if shouldKick then task.wait(0.1); LocalPlayer:Kick("Saved by Zenn") end
end

local function executeDefense(targetName, shouldKick)
    if (shouldKick and not spamKickEnabled) or (not shouldKick and not spamNoKickEnabled) then return end
    if punishedPlayers[targetName] then return end
    punishedPlayers[targetName] = true
    local targetPlayer
    for _, p in ipairs(Players:GetPlayers()) do if p.Name == targetName then targetPlayer = p; break end end
    if not targetPlayer then return end
    sendCommand(defenseCommand, targetPlayer)
    task.wait(0.05)
    executeAPSpam(targetName, shouldKick)
    task.delay(30, function() punishedPlayers[targetName] = nil end)
end

local function executeAntiTP(targetName)
    if not antiTPEnabled then return end
    if antiTPCooldowns[targetName] then return end
    antiTPCooldowns[targetName] = true
    local targetPlayer
    for _, p in ipairs(Players:GetPlayers()) do if p.Name == targetName then targetPlayer = p; break end end
    if not targetPlayer then return end
    sendCommand("balloon", targetPlayer)
    task.wait(0.02)
    sendCommand("jail", targetPlayer)
    task.delay(5, function() antiTPCooldowns[targetName] = nil end)
end

-- =============================================
--   BASE DEFENDER & ANTI-TP SYSTEMS
-- =============================================
local function startBaseDefender()
    local myPlot
    for i=1,10 do myPlot = findMyPlot(); if myPlot then break end; task.wait(1) end
    if not myPlot then return end

    task.spawn(function()
        if notificationRemote then
            notificationRemote.OnClientEvent:Connect(function(msg)
                if typeof(msg) ~= "string" then return end
                if not msg:find("Someone is stealing your") and not msg:find("Someone is robbing your") then return end
                task.spawn(function()
                    task.wait(0.005)
                    local inPlot = getPlayersInMyPlot()
                    if #inPlot == 0 then return end
                    if #inPlot == 1 then executeDefense(inPlot[1].Name, spamKickEnabled); return end
                    local decor = myPlot:FindFirstChild("Decorations")
                    local animals = myPlot:FindFirstChild("AnimalPodiums")
                    local nearest, bestDist
                    for _, plr in ipairs(inPlot) do
                        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local dist = math.huge
                            if decor then local m = decor:FindFirstChild("Model"); if m then dist = math.min(dist, (hrp.Position - m:GetPivot().Position).Magnitude) end end
                            if animals then for _, a in ipairs(animals:GetChildren()) do dist = math.min(dist, (hrp.Position - a:GetPivot().Position).Magnitude) end end
                            if not nearest or dist < bestDist then nearest = plr; bestDist = dist end
                        end
                    end
                    if nearest then executeDefense(nearest.Name, spamKickEnabled) else executeDefense(inPlot[1].Name, spamKickEnabled) end
                end)
            end)
        else
            local playerGui = LocalPlayer:WaitForChild("PlayerGui")
            local tracked = {}
            RunService.RenderStepped:Connect(function()
                if not spamKickEnabled and not spamNoKickEnabled then return end
                for _, gui in ipairs(playerGui:GetDescendants()) do
                    if (gui:IsA("TextLabel") or gui:IsA("TextButton")) and gui.Visible then
                        local txt = gui.Text
                        if txt and txt ~= "" then
                            local low = string.lower(stripTags(txt))
                            if (string.find(low, "stealing", 1, true) or string.find(low, "robbing", 1, true)) and not tracked[gui] then
                                tracked[gui] = true
                                task.spawn(function()
                                    task.wait(0.005)
                                    local inPlot = getPlayersInMyPlot()
                                    if #inPlot == 0 then return end
                                    if #inPlot == 1 then executeDefense(inPlot[1].Name, spamKickEnabled); return end
                                    local decor = myPlot:FindFirstChild("Decorations")
                                    local animals = myPlot:FindFirstChild("AnimalPodiums")
                                    local nearest, bestDist
                                    for _, plr in ipairs(inPlot) do
                                        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                                        if hrp then
                                            local dist = math.huge
                                            if decor then local m = decor:FindFirstChild("Model"); if m then dist = math.min(dist, (hrp.Position - m:GetPivot().Position).Magnitude) end end
                                            if animals then for _, a in ipairs(animals:GetChildren()) do dist = math.min(dist, (hrp.Position - a:GetPivot().Position).Magnitude) end end
                                            if not nearest or dist < bestDist then nearest = plr; bestDist = dist end
                                        end
                                    end
                                    if nearest then executeDefense(nearest.Name, spamKickEnabled) else executeDefense(inPlot[1].Name, spamKickEnabled) end
                                end)
                                task.delay(5, function() tracked[gui] = nil end)
                                break
                            end
                        end
                    end
                end
            end)
        end
    end)
end

local function startAntiTPSystem()
    task.spawn(function()
        task.wait(3)
        local myPlot = findMyPlot(); if not myPlot then return end
        local decor = myPlot:FindFirstChild("Decorations")
        local animals = myPlot:FindFirstChild("AnimalPodiums")
        local detected = {}
        while task.wait(0.1) do
            if not antiTPEnabled then continue end
            local inPlot = getPlayersInMyPlot()
            for _, plr in ipairs(inPlot) do
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local tooClose = false
                    if decor then
                        local m = decor:FindFirstChild("Model")
                        if m and (hrp.Position - m:GetPivot().Position).Magnitude < 20 then tooClose = true end
                    end
                    if animals and not tooClose then
                        for _, a in ipairs(animals:GetChildren()) do
                            for _, p in ipairs(a:GetDescendants()) do
                                if p:IsA("BasePart") then
                                    p.CanTouch = true
                                    for _, t in ipairs(p:GetTouchingParts()) do
                                        if t.Parent == plr.Character then tooClose = true; break end
                                    end
                                end
                                if tooClose then break end
                            end
                            if tooClose then break end
                        end
                    end
                    if tooClose and not detected[plr.Name] then
                        detected[plr.Name] = true
                        executeAntiTP(plr.Name)
                        task.delay(2, function() detected[plr.Name] = nil end)
                    end
                end
            end
        end
    end)
end

