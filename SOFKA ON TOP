-- =============================================
local function createRedToggle(parent, yPos, text)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -20, 0, 42)
    container.Position = UDim2.new(0, 10, 0, yPos)
    container.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(1, -52, 1, 0)
    label.Position = UDim2.new(0, 2, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 180, 100)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left

    local pill = Instance.new("TextButton", container)
    pill.Size = UDim2.new(0, 44, 0, 22)
    pill.Position = UDim2.new(1, -44, 0.5, -11)
    pill.BackgroundColor3 = RED_OFF
    pill.Text = ""
    pill.AutoButtonColor = false
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local dot = Instance.new("Frame", pill)
    dot.Size = UDim2.new(0, 16, 0, 16)
    dot.Position = UDim2.new(0, 3, 0.5, -8)
    dot.BackgroundColor3 = Color3.fromRGB(120, 30, 20)
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local enabled = false
    local function setState(on)
        enabled = on
        local targetPill = on and RED_ON or RED_OFF
        local targetDot  = on and Color3.fromRGB(255, 80, 60) or Color3.fromRGB(120, 30, 20)
        local targetPos  = on and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)

        TweenService:Create(pill, TweenInfo.new(0.15), {BackgroundColor3 = targetPill}):Play()
        TweenService:Create(dot,  TweenInfo.new(0.15), {BackgroundColor3 = targetDot, Position = targetPos}):Play()
    end

    return pill, setState, function() return enabled end
end

